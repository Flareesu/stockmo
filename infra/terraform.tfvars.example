# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars — it contains secrets.

aws_region   = "ap-southeast-1"
environment  = "production"
bucket_name  = "stockmo-vehicle-imports"

# Supabase credentials (from your client project)
supabase_url              = "https://eoxwapxwdshfmlyubfkw.supabase.co"
supabase_service_role_key = "YOUR_SERVICE_ROLE_KEY_HERE"

# CORS — restrict to your Vercel domain in production
allowed_origin = "https://your-stockmo-app.vercel.app"
