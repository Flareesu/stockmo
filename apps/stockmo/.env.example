# ─── StockMo Client App Environment Variables ─────────────────────────────────
# Copy this to .env and fill in values from your Supabase dashboard.
# NEVER commit .env to version control.

# This dealership's Supabase project (anon/publishable key — safe to expose)
VITE_SUPABASE_URL=https://<client-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Operator project Edge Function base URL (for feature flags)
VITE_OPERATOR_FUNCTIONS_URL=https://<operator-ref>.supabase.co/functions/v1

# This client's identifier (must match operator.clients.slug)
VITE_CLIENT_SLUG=your-dealership-slug

# Per-client read-only API key for the get-flags endpoint
# Generated during client provisioning
VITE_CLIENT_API_KEY=stockmo_client_...

# App version (shown in Master DB section)
VITE_APP_VERSION=2.0.0
